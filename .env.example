# MongoDB Connection
MONGODB_URI=
# Collection-ууд байрлах database-ийн нэр (Atlas-д өгөгдөл аль DB-д байгаагаар тааруулна).
# URI дээр /databaseName байхгүй бол заавал бөглөж өгөх нь зөв (буруу DB-д холбогдвол хоосон харагдана).
MONGODB_DB=

# JWT Secret for Custom Auth (Mobile)
JWT_SECRET=           # Minimum 64-character random string recommended

# Admin Override Access
# (Master password has been removed for security compliance)
# Clerk Authentication (Web/General)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Email Services (Transactional Notifications)
RESEND_API_KEY=

# Image Storage (Cloudinary Asset Management)
CLOUDINARY_CLOUD_NAME=

# LiveKit (Real-time Video/Audio)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Firebase Admin (Push Notifications)
FIREBASE_SERVICE_ACCOUNT=  # Base64 or stringified JSON of your private key service account

# WebSocket (Real-time Messaging)
NEXT_PUBLIC_WS_URL=        # wss://your-message-server.com

# Android Mobile Build Signing
ANDROID_KEYSTORE_PATH=
ANDROID_KEYSTORE_ALIAS=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_PASSWORD=

# App Store Compliance
NEXT_PUBLIC_PRIVACY_URL=https://gevabal.mn/en/privacy
