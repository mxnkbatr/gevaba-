{
  "name": "tibetan",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 --webpack",
    "dev:webpack": "next dev -H 0.0.0.0 --webpack",
    "dev:turbopack": "next dev -H 0.0.0.0",
    "prebuild": "cross-env CAPACITOR_BUILD=true node scripts/capacitor-dynamic.js remove",
    "postbuild": "cross-env CAPACITOR_BUILD=true node scripts/capacitor-dynamic.js restore",
    "build:rust": "node scripts/build-rust.mjs",
    "build": "cross-env CAPACITOR_BUILD=true next build --webpack",
    "ionic:build": "CAPACITOR_BUILD=true npm run build && npx cap sync",
    "build:mobile": "CAPACITOR_BUILD=true npm run build && npx cap sync",
    "build:mobile:offline": "CAPACITOR_BUILD=true npm run build && npx cap sync",
    "build:android": "npm run build:mobile && npx cap open android",
    "build:ios": "npm run build:mobile && npx cap open ios",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx database/seed.ts",
    "db:indexes": "node scripts/create-indexes.js",
    "perf:stats": "curl http://localhost:3000/api/performance/stats | json_pp",
    "cache:clear": "curl -X POST http://localhost:3000/api/performance/stats?action=clearCache",
    "mobile:sync": "CAPACITOR_BUILD=true npm run build && npx cap sync",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios",
    "mobile:update": "npm run build:mobile && npx cap copy && npx cap update",
    "mobile:clean": "node scripts/clean-mobile-builds.mjs",
    "analyze": "cross-env ANALYZE=true npm run build",
    "postinstall": "patch-package"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@capgo/capacitor-navigation-bar": "^8.1.8",
    "@clerk/nextjs": "^6.36.5",
    "@livekit/components-react": "^2.9.17",
    "@livekit/components-styles": "^1.2.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/kv": "^3.0.0",
    "ably": "^2.21.0",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.23.26",
    "jose": "^6.1.3",
    "livekit-client": "^2.17.1",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^0.562.0",
    "mongodb": "^7.0.0",
    "next": "16.1.6",
    "next-cloudinary": "^6.17.5",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.12",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "redis": "^5.11.0",
    "resend": "^6.6.0",
    "rust-modules": "file:rust-modules/pkg",
    "svix": "^1.82.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/network": "^8.0.0",
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
